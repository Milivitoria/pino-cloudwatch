  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dbhowell/pino-cloudwatch/issues"
  },
  "homepage": "https://github.com/dbhowell/pino-cloudwatch#readme",
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1038.0",
    "chunky-stream": "^0.3.0",
    "split2": "^4.0.0",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/split2": "^4.2.3",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.0.0",
    "pino": "^10.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
