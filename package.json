{
  "name": "pino-cloudwatch",
  "version": "6.0.0",
  "description": "CloudWatch Logs transport for pino",
  "main": "dist/index.js",
  "bin": {
    "pino-cloudwatch": "dist/bin/pino-cloudwatch.js"
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --ext .ts",
